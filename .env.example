# ─── DATENBANK ────────────────────────────────────────────────────────────────
# PostgreSQL Verbindungs-URL (lokal via Docker)
DATABASE_URL="postgresql://postgres:password@localhost:5432/dont_forget"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Basis-URL der App (im Development: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# Geheimer Schlüssel für JWT-Signierung – generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET="dein-super-geheimer-schluessel-hier"

# ─── GOOGLE OAUTH (optional) ──────────────────────────────────────────────────
# Erstellen unter: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
